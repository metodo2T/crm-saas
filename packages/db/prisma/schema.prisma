generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Organization {
  id           String               @id @default(uuid())
  clerkOrgId   String               @unique
  name         String
  slug         String               @unique
  logoUrl      String?
  planId       String               // cache denormalizado — sempre atualizado em transação junto com Subscription
  plan         Plan                 @relation(fields: [planId], references: [id])
  members      OrganizationMember[]
  subscription Subscription?
  auditLogs    AuditLog[]
  leads        Lead[]
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
}

model User {
  id          String               @id @default(uuid())
  clerkUserId String               @unique
  email       String
  name        String
  avatarUrl   String?
  memberships OrganizationMember[]
  auditLogs   AuditLog[]
  leads       Lead[]
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  @@index([email])
}

model OrganizationMember {
  organizationId String
  userId         String
  role           OrgRole      @default(MEMBER)
  joinedAt       DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([organizationId, userId])
  @@index([userId])
}

enum OrgRole {
  ADMIN
  MEMBER
}

model Plan {
  id            String         @id @default(uuid())
  name          PlanTier       @unique
  stripePriceId String         @unique
  maxUsers      Int
  maxLeads      Int            // -1 = ilimitado
  maxWhatsapp   Int            // -1 = ilimitado
  features      Json
  organizations Organization[]
  subscriptions Subscription[]
}

enum PlanTier {
  STARTER
  PRO
  AGENCY
}

model Subscription {
  id               String             @id @default(uuid())
  organizationId   String             @unique
  planId           String
  stripeSubId      String             @unique
  stripeCustomerId String             @unique
  status           SubscriptionStatus
  currentPeriodEnd DateTime
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan             Plan               @relation(fields: [planId], references: [id])

  @@index([planId])
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
}

model AuditLog {
  id             String       @id @default(uuid())
  organizationId String
  userId         String?
  action         String
  resource       String
  resourceId     String?
  metadata       Json?
  createdAt      DateTime     @default(now())
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [userId], references: [id])

  @@index([organizationId, createdAt])
}

model Lead {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  email          String?
  phone          String?
  company        String?
  notes          String?
  status         LeadStatus   @default(NOVO)
  source         LeadSource
  assignedToId   String?
  assignedTo     User?        @relation(fields: [assignedToId], references: [id])
  utmSource      String?
  utmMedium      String?
  utmCampaign    String?
  utmContent     String?
  utmTerm        String?
  fbclid         String?
  gclid          String?
  convertedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId, createdAt])
  @@index([organizationId, status])
  @@index([organizationId, source])
  @@index([assignedToId])
}

enum LeadStatus {
  NOVO
  CONTATADO
  QUALIFICADO
  CONVERTIDO
  DESCARTADO
}

enum LeadSource {
  MANUAL
  FORM
  CSV
  WHATSAPP
}
