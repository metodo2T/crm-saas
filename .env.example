# ── Banco de dados (Postgres interno ao Docker) ───────────────────────────────
POSTGRES_USER=crm
POSTGRES_PASSWORD=troque_esta_senha
POSTGRES_DB=crm_saas

# ── Redis (interno ao Docker) ─────────────────────────────────────────────────
REDIS_PASSWORD=troque_esta_senha_redis

# ── Clerk ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...
CLERK_WEBHOOK_SECRET=whsec_...

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# ── Domínio e SSL ─────────────────────────────────────────────────────────────
# Domínio ou hostname da VPS (usado pelo scripts/init-ssl.sh)
DOMAIN=srv1663592.hstgr.cloud
# Email para notificações de expiração do Let's Encrypt
SSL_EMAIL=seu@email.com

# ── URLs públicas ─────────────────────────────────────────────────────────────
# Antes do SSL: http://  |  Depois do SSL: https://
NEXT_PUBLIC_API_URL=https://srv1663592.hstgr.cloud/api
