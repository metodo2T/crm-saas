# ── Clerk ─────────────────────────────────────────────────────────────────────
# Found at: https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...

# Clerk routing — must match your sign-in/sign-up pages
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── API ───────────────────────────────────────────────────────────────────────
# URL of the deployed NestJS API (no trailing slash)
NEXT_PUBLIC_API_URL=https://api.seu-crm.com
