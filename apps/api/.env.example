# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string (e.g. from Neon, Railway, or Supabase)
DATABASE_URL=postgresql://user:password@host:5432/crm_saas

# ── Redis ─────────────────────────────────────────────────────────────────────
# Redis connection string (e.g. from Upstash)
REDIS_URL=redis://default:password@host:6379

# ── Clerk ─────────────────────────────────────────────────────────────────────
# Found at: https://dashboard.clerk.com → API Keys
CLERK_SECRET_KEY=sk_live_...

# Found at: https://dashboard.clerk.com → Webhooks → your endpoint → Signing Secret
CLERK_WEBHOOK_SECRET=whsec_...

# ── Stripe ────────────────────────────────────────────────────────────────────
# Found at: https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...

# Found at: https://dashboard.stripe.com → Developers → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Stripe Price IDs ──────────────────────────────────────────────────────────
# Create products at: https://dashboard.stripe.com → Products
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_AGENCY=price_...

# ── Z-API (WhatsApp) ──────────────────────────────────────────────────────────
# Encontre em: https://app.z-api.io → sua conta → Security Token
ZAPI_CLIENT_TOKEN=seu_client_token_aqui

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
